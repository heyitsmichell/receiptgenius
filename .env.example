# ReceiptGenius Environment Variables Example
# Copy this file to .env and fill in your actual credentials.

# Google AI Studio API Key (Get your key from https://aistudio.google.com/)
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# AI Model for OCR Vision Scanning
EXPO_PUBLIC_GEMINI_MODEL=gemma-4-31b-it

# Google OAuth 2.0 Client ID for direct Google Sheets REST API syncing (from Google Cloud Console)
EXPO_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id_here

# Optional: Google Apps Script Webhook URL for advanced webhook syncing
# EXPO_PUBLIC_WEBHOOK_URL=https://script.google.com/macros/s/your_script_id/exec
